PORT="4888"
BOT_TOKEN=""
EMOJI_DOMAIN="https://emojipedia.org/"

# Legacy-domain sunset. Requests arriving on LEGACY_DOMAIN (or any subdomain of
# it) get 410 Gone pointing at CANONICAL_ORIGIN. LEGACY_SUNSET is the date the
# old domain stops resolving, surfaced in the error and the RFC 8594 Sunset header.
LEGACY_DOMAIN="lyo.su"
CANONICAL_ORIGIN="https://quote.yuri.ly"
LEGACY_SUNSET="2026-09-01T00:00:00Z"
